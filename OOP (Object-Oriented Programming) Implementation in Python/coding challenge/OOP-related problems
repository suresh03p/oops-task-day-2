# 9. School Result Processing
# ==================================================

class StudentResult:

    def __init__(self, name, marks):
        self.name = name
        self.marks = marks

    def grade(self):

        if self.marks >= 90:
            return "A"

        elif self.marks >= 75:
            return "B"

        elif self.marks >= 50:
            return "C"

        return "Fail"


result = StudentResult(
    "Suresh",
    88
)

print("Grade:", result.grade())

print("-" * 40)

