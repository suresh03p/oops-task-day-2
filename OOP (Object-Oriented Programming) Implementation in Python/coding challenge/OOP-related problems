# 6. Shopping Cart
# ==================================================

class ShoppingCart:

    def __init__(self):
        self.items = []

    def add_item(self, item, price):
        self.items.append((item, price))

    def total_amount(self):

        total = 0

        for item, price in self.items:
            total += price

        return total


cart = ShoppingCart()

cart.add_item("Laptop", 50000)
cart.add_item("Mouse", 500)

print("Total Amount:", cart.total_amount())

print("-" * 40)

